<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <div class="flex items-center">
      <%= link_to gdpr_questionnaire_path(@questionnaire), class: "text-gray-400 hover:text-gray-500 mr-4" do %>
        <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
        </svg>
      <% end %>
      <h1 class="text-3xl font-bold text-gray-900">New Section</h1>
    </div>
    <p class="mt-2 text-sm text-gray-700">Add a new section to <%= @questionnaire.title %></p>
  </div>

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <%= render "form", questionnaire: @questionnaire, section: @section %>
    </div>
  </div>
</div>
