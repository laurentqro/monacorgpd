<%= form_with model: [:gdpr, questionnaire, section, question], local: true, class: "space-y-6" do |f| %>
  <% if question.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(question.errors.count, "error") %> prohibited this question from being saved:
          </h3>
          <ul class="mt-2 text-sm text-red-700 list-disc pl-5">
            <% question.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :question_text, "Question", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :question_text, rows: 2, class: "mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md", placeholder: "Enter your question..." %>
  </div>

  <div>
    <%= f.label :question_type, "Type", class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :question_type,
        options_for_select(Gdpr::Question.question_types.keys.map { |t| [t.humanize, t] }, question.question_type),
        {},
        class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm rounded-md" %>
    <p class="mt-2 text-sm text-gray-500">
      Select the type of response for this question
    </p>
  </div>

  <div>
    <%= f.label :help_text, "Help Text (Optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :help_text, rows: 2, class: "mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md", placeholder: "Provide additional guidance..." %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :weight, "Weight", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :weight, step: 0.01, class: "mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md" %>
      <p class="mt-1 text-xs text-gray-500">Scoring weight (default: 1.0)</p>
    </div>

    <div class="flex items-center mt-6">
      <div class="flex items-center h-5">
        <%= f.check_box :is_required, class: "focus:ring-indigo-500 h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
      </div>
      <div class="ml-3 text-sm">
        <%= f.label :is_required, "Required question", class: "font-medium text-gray-700" %>
      </div>
    </div>
  </div>

  <div class="flex justify-end space-x-3 pt-4 border-t border-gray-200">
    <%= link_to "Cancel", gdpr_questionnaire_section_questions_path(questionnaire, section), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit question.persisted? ? "Update Question" : "Create Question", class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
  </div>
<% end %>

<%# Note: Answer choices management will be added in a future update %>
<% if question.persisted? && question.requires_choices? %>
  <div class="mt-6 bg-yellow-50 border-l-4 border-yellow-400 p-4">
    <div class="flex">
      <div class="ml-3">
        <p class="text-sm text-yellow-700">
          <strong>Note:</strong> This question type requires answer choices. Answer choice management will be available in a future update. For now, you can manage them via Rails console.
        </p>
      </div>
    </div>
  </div>
<% end %>
