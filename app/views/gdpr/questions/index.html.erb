<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <%= link_to gdpr_questionnaire_path(@questionnaire), class: "text-gray-400 hover:text-gray-500 mr-4" do %>
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        <% end %>
        <div>
          <h1 class="text-3xl font-bold text-gray-900"><%= @section.title %></h1>
          <p class="mt-1 text-sm text-gray-600"><%= @questionnaire.title %></p>
        </div>
      </div>
      <%= link_to "Add Question", new_gdpr_questionnaire_section_question_path(@questionnaire, @section), class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
    </div>
  </div>

  <% if @questions.any? %>
    <div class="bg-white shadow overflow-hidden sm:rounded-md">
      <ul role="list" class="list-none divide-y divide-gray-200">
        <% @questions.each do |question| %>
          <li class="px-4 py-4 sm:px-6 hover:bg-gray-50">
            <div class="flex items-center justify-between">
              <div class="flex-1 min-w-0">
                <div class="flex items-start">
                  <span class="text-sm text-gray-500 mr-3"><%= question.order_index + 1 %>.</span>
                  <div class="flex-1">
                    <p class="text-sm font-medium text-gray-900">
                      <%= question.question_text %>
                      <% if question.is_required %>
                        <span class="text-red-500">*</span>
                      <% end %>
                    </p>
                    <% if question.help_text.present? %>
                      <p class="mt-1 text-sm text-gray-500"><%= question.help_text %></p>
                    <% end %>
                    <div class="mt-2 flex items-center space-x-4">
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        <%= question.question_type.humanize %>
                      </span>
                      <% if question.answer_choices.any? %>
                        <span class="text-xs text-gray-500">
                          <%= pluralize(question.answer_choices.count, 'choice') %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
              <div class="ml-5 flex items-center space-x-3">
                <%= link_to "Edit", edit_gdpr_questionnaire_section_question_path(@questionnaire, @section, question), class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" %>
                <%= button_to "Delete", gdpr_questionnaire_section_question_path(@questionnaire, @section, question), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg shadow">
      <svg class="mx-auto h-12 w-12 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No questions</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by creating a new question.</p>
      <div class="mt-6">
        <%= link_to "Add Question", new_gdpr_questionnaire_section_question_path(@questionnaire, @section), class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
      </div>
    </div>
  <% end %>
</div>
