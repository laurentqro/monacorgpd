<%
  answer_value = answer.answer_value || {}
%>

<% case question.question_type.to_sym %>
<% when :single_choice %>
  <% choice = question.answer_choices.find_by(id: answer_value["choice_id"]) %>
  <% if choice %>
    <strong><%= choice.choice_text %></strong>
    <% if choice.score %>
      <span class="ml-2 text-xs text-gray-500">(Score: <%= choice.score %>)</span>
    <% end %>
  <% else %>
    <span class="text-gray-500 italic">Invalid choice selected</span>
  <% end %>

<% when :multiple_choice %>
  <% choice_ids = Array(answer_value["choice_ids"]) %>
  <% choices = question.answer_choices.where(id: choice_ids) %>
  <% if choices.any? %>
    <ul class="list-disc list-inside space-y-1">
      <% choices.each do |choice| %>
        <li>
          <%= choice.choice_text %>
          <% if choice.score %>
            <span class="text-xs text-gray-500">(Score: <%= choice.score %>)</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <span class="text-gray-500 italic">No choices selected</span>
  <% end %>

<% when :yes_no %>
  <strong class="<%= answer_value['value'] == 'yes' ? 'text-green-700' : 'text-red-700' %>">
    <%= answer_value["value"]&.capitalize %>
  </strong>

<% when :text_short, :text_long %>
  <%= answer_value["text"] || "<span class='text-gray-500 italic'>No answer</span>".html_safe %>

<% when :rating_scale %>
  <div class="flex items-center">
    <% (1..5).each do |rating| %>
      <% if rating <= (answer_value["rating"]&.to_i || 0) %>
        <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      <% else %>
        <svg class="h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      <% end %>
    <% end %>
    <span class="ml-2 text-sm font-medium text-gray-700"><%= answer_value["rating"] %> / 5</span>
  </div>
<% end %>
