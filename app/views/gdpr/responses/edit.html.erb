<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8" data-response-id="<%= @response.id %>">
  <div class="mb-8">
    <div class="sm:flex sm:items-center sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-gray-900"><%= @response.questionnaire.title %></h1>
        <p class="mt-2 text-sm text-gray-600">
          Progress: <%= @response.completion_percentage.round %>%
          <span class="text-gray-400">•</span>
          Started <%= time_ago_in_words(@response.started_at) %> ago
        </p>
      </div>
      <div class="mt-4 sm:mt-0">
        <%= button_to "Complete Assessment", submit_gdpr_response_path(@response), method: :post, data: { confirm: "Are you sure you want to submit this assessment? You won't be able to edit it afterwards." }, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
      </div>
    </div>
  </div>

  <% if @response.notes.present? %>
    <div class="mb-6 bg-gray-50 border border-gray-200 rounded-lg p-4">
      <h3 class="text-sm font-medium text-gray-900 mb-2">Assessment Notes</h3>
      <p class="text-sm text-gray-700"><%= @response.notes %></p>
    </div>
  <% end %>

  <div class="space-y-8">
    <% @sections.each_with_index do |section, section_index| %>
      <div class="bg-white shadow sm:rounded-lg" id="section-<%= section.id %>">
        <div class="px-4 py-5 sm:p-6">
          <div class="mb-6">
            <h2 class="text-xl font-semibold text-gray-900">
              <%= section_index + 1 %>. <%= section.title %>
            </h2>
            <% if section.description.present? %>
              <p class="mt-2 text-sm text-gray-600"><%= section.description %></p>
            <% end %>
          </div>

          <div class="space-y-6">
            <% section.questions.ordered.each_with_index do |question, question_index| %>
              <div class="border-t border-gray-200 pt-6 first:border-0 first:pt-0" data-controller="question-answer" data-question-id="<%= question.id %>">
                <div class="flex items-start">
                  <span class="flex-shrink-0 text-sm font-medium text-gray-500 mr-3">
                    <%= section_index + 1 %>.<%= question_index + 1 %>
                  </span>
                  <div class="flex-1">
                    <label class="block text-sm font-medium text-gray-900">
                      <%= question.question_text %>
                      <% if question.is_required %>
                        <span class="text-red-500">*</span>
                      <% end %>
                    </label>
                    <% if question.help_text.present? %>
                      <p class="mt-1 text-sm text-gray-500"><%= question.help_text %></p>
                    <% end %>

                    <div class="mt-3">
                      <%= render "gdpr/responses/question_input", question: question, response: @response, answer: @answers[question.id] %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-8 flex justify-end">
    <%= button_to "Complete Assessment", submit_gdpr_response_path(@response), method: :post, data: { confirm: "Are you sure you want to submit this assessment? You won't be able to edit it afterwards." }, class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500" %>
  </div>
</div>
