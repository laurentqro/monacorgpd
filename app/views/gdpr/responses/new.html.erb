<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <div class="flex items-center mb-4">
        <%= link_to gdpr_questionnaire_path(@questionnaire), class: "text-gray-400 hover:text-gray-500 mr-4" do %>
          <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
          </svg>
        <% end %>
        <h1 class="text-2xl font-bold text-gray-900">Start New Assessment</h1>
      </div>

      <div class="mt-4">
        <h2 class="text-lg font-medium text-gray-900"><%= @questionnaire.title %></h2>
        <% if @questionnaire.description.present? %>
          <p class="mt-2 text-sm text-gray-600"><%= @questionnaire.description %></p>
        <% end %>
      </div>

      <div class="mt-6 border-t border-gray-200 pt-6">
        <h3 class="text-sm font-medium text-gray-900 mb-4">Assessment Overview</h3>
        <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div class="border border-gray-200 rounded-lg px-4 py-3">
            <dt class="text-sm font-medium text-gray-500">Sections</dt>
            <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @questionnaire.sections.count %></dd>
          </div>
          <div class="border border-gray-200 rounded-lg px-4 py-3">
            <dt class="text-sm font-medium text-gray-500">Total Questions</dt>
            <dd class="mt-1 text-2xl font-semibold text-gray-900"><%= @questionnaire.questions.count %></dd>
          </div>
        </dl>
      </div>

      <div class="mt-6 bg-blue-50 border-l-4 border-blue-400 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-blue-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <p class="text-sm text-blue-700">
              <strong>Note:</strong> Your responses will be automatically saved as you progress. You can pause and resume at any time.
            </p>
          </div>
        </div>
      </div>

      <%= form_with model: @response, url: gdpr_questionnaire_responses_path(@questionnaire), scope: :response, local: true, class: "mt-6" do |f| %>
        <div>
          <%= f.label :notes, "Additional Notes (Optional)", class: "block text-sm font-medium text-gray-700" %>
          <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm border-gray-300 rounded-md", placeholder: "Add any context or notes about this assessment..." %>
        </div>

        <div class="mt-6 flex justify-end space-x-3">
          <%= link_to "Cancel", gdpr_questionnaire_path(@questionnaire), class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
          <%= f.submit "Start Assessment", class: "inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
